{
  "name": "math-reasoning-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "node -e \"const fs=require('fs'); fs.rmSync('tsconfig.tsbuildinfo',{force:true}); fs.mkdirSync('.next/types',{recursive:true}); fs.closeSync(fs.openSync('.next/types/cache-life.d.ts','a'));\" && next typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "api:export": "python3 ../scripts/export_openapi.py",
    "api:codegen": "openapi-typescript ./lib/api/generated/openapi.json -o ./lib/api/generated/schema.d.ts",
    "api:sync": "npm run api:export && npm run api:codegen",
    "api:check": "npm run api:sync && git diff --exit-code ./lib/api/generated/"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "katex": "^0.16.11",
    "next": "^16.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.0"
  }
}
